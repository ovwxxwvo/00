-- Last Change: 2024.11.25


local module = "conform"
if not pcall(require, module) then return end

require("conform").setup({
  formatters_by_ft = {
    html       = { "prettier" },
    css        = { "prettier" },
    javascript = { "prettier" },
  },
  vim.keymap.set('n', '<C-f>', function()
    require("conform").format({ async = true })
    end)
  })


