# TMUX config, terminal multiplexer.
# Maintainer:	 Jessee Chan <CYPHER0@foxmail.com>
# Last Change: 2023.05.05


set-hook -g window-renamed[10] " \
  run -b ~/.config/tmux/hook/key.sh  \;  \
  "

set-hook -g pane-focus-in[10] " \
  run -b ~/.config/tmux/hook/key.sh  \;  \
  "

